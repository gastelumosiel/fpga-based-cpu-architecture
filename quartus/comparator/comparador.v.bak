// Comparador

module comparador (
input x1,x2,x3,x4,y1,y2,y3,y4,

output z1,z2,z3);

wire a1;
wire b1;
wire a1+;
wire b1+;

wire a2;
wire b2;
wire a2+;
wire b2+;

wire a3;
wire b3;
wire a3+;
wire b3+;

wire a4;
wire b4;
wire a4+;
wire b4+;

// Asignacion de ecuaciones

// Celda 1
assign a1 = 0;
assign b1 = 0;

assign a1+ = (~x1 & y1 & ~b1) | a1;
assign b1+ = (x1 & ~y1 & ~a1) | b1;

// Celda 2

assign a2 = a1+;
assign b2 = b1+;

assign a2+ = (~x2 & y2 & ~b2) | a2;
assign b2+ = (x2 & ~y2 & ~a2) | b2;

// Celda 3

assign a3 = a2+;
assign b3 = b2+;

assign a3+ = (~x3 & y3 & ~b3) | a3;
assign b3+ = (x3 & ~y3 & ~a3) | b3;

// Celda 4

assign a4 = a3+;
assign b4 = b3+;

assign a4+ = (~x4 & y4 & ~b4) | a4;
assign b4+ = (x4 & ~y4 & ~a4) | b4;

// Salidas

assign z1 = a4+;
assign z2 = ~a4+ & ~b4+;
assign z3 = b4+;

endmodule